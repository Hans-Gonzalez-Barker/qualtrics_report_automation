# --- Python System Files ---
# These are generated by Python when you run the script; they don't belong in Git.
__pycache__/
*.py[cod]
*$py.class

# --- Environment & Secrets ---
# Crucial: This prevents your Qualtrics API keys and local virtual environment from being shared.
.env
.venv/
venv/

# --- Project Specific Data (Privacy) ---
# Essential: This ensures student survey data and temporary files stay on your local machine.
data/
output/
reports/

# --- IDE Settings ---
# Prevents your personal PyCharm configurations from conflicting with your supervisor's settings.
.idea/
.vscode/